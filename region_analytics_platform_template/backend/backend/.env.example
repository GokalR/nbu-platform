# Copy this file to .env (in the same folder) and fill in your values.

# Required: your OpenAI API key (either name works).
OPENAI=sk-...
# OPENAI_API_KEY=sk-...

# Required after `python ingest.py` — paste the printed id here.
VECTOR_STORE_ID=

# Optional overrides.
RAG_MODEL=gpt-5.4-mini
VECTOR_STORE_NAME=uzbekistan-regional-analytics
RAG_TIMEOUT_SEC=180

# Optional: comma-separated allowed origins for CORS. Default "*".
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
