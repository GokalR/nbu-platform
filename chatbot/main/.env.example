# Copy to .env and fill in. .env is gitignored.

# --- Source data ---
# Absolute or relative path to dir containing the source JSON files.
# Filenames follow the cerr_region_<id>.json convention from the source pipeline.
SOURCE_DIR=./cerr_runs

# --- PostgreSQL (used in later phases) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cerr
POSTGRES_USER=cerr
POSTGRES_PASSWORD=change_me
# Optional override; if set, takes precedence over the parts above.
# DATABASE_URL=postgresql+psycopg://cerr:change_me@localhost:5432/cerr

# --- LLM (optional; required only when using LlmPlanner) ---
# Safety does NOT depend on the model behaving. SQL guard, semantic catalog,
# and read-only executor reject anything unsafe regardless of LLM output.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
LLM_MODEL=claude-opus-4-7
# Planner mode: 'single_stage' (default, monolithic prompt) or
# 'two_stage' (schema linking -> SQL generation; smaller prompts).
LLM_PLANNER_MODE=single_stage
# Query pipeline: 'legacy' or 'evidence' (multi-SQL evidence pack).
# QUERY_PIPELINE_MODE=evidence
# Conversation memory: 'off' or 'ephemeral' (per-session, in-process).
# QUERY_MEMORY_MODE=off
# Final answer narrator: 'deterministic' or 'llm'.
# ANSWER_NARRATOR_MODE=deterministic

# --- Runtime ---
APP_ENV=dev
LOG_LEVEL=INFO
