# Docker Compose runtime template.
# Copy to .env for local container runs:
#   cp .env.docker.example .env

# --- PostgreSQL ---
POSTGRES_DB=cerr
POSTGRES_USER=cerr
POSTGRES_PASSWORD=change_this_strong_password

# --- LLM ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
LLM_MODEL=gpt-5.4
LLM_PLANNER_MODE=two_stage

# --- Chatbot runtime ---
QUERY_PIPELINE_MODE=evidence
QUERY_MEMORY_MODE=ephemeral
ANSWER_NARRATOR_MODE=llm

# --- Runtime ---
APP_ENV=prod
LOG_LEVEL=INFO
