# Copy to .env.local for local dev, .env.production for production build.
# When unset, the app runs in static/demo mode — Excel upload disabled,
# no calls go to the backend.

VITE_API_URL=http://localhost:8000

# CERR Mahalla Analytics bundle — Flask service that hosts
# reference_analytics_platform/platform/. Deployed as its own Railway service
# reading from R2. The /regions-v2 page iframes this URL.
# Local dev: http://localhost:5000   Prod: https://<service>.up.railway.app
VITE_CERR_BUNDLE_URL=http://localhost:5000

# Yandex Maps JS API v2.1 key used by /maps/fergana-education/index.html.
# Injected by the rs-yandex-key Vite plugin at dev-serve and build time.
# Rotate in Cloudflare Pages env settings (triggers a rebuild).
VITE_YANDEX_MAPS_API_KEY=
